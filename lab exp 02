import numpy as np

# 3x3 matrix
# Rows = Different products
# Columns = Sales prices during the month

sales_data = np.array([
    [100, 120, 110],
    [200, 180, 220],
    [150, 160, 170]
])

# Calculate the average price of all products sold
average_price = np.mean(sales_data)

print("Sales Data:")
print(sales_data)

print("\nAverage Price of All Products Sold =", average_price)
